# EmailJS — contact form (https://www.emailjs.com)
# Copy this file to `.env.local` and fill in your values.
# Restart the dev server after saving: yarn dev

# Email Services → your connected service (e.g. Gmail)
NEXT_PUBLIC_SERVICE_ID=service_xxxxxxxx

# Email Templates → your template ID
NEXT_PUBLIC_TEMPLATE_ID=template_xxxxxxxx

# Account → API Keys → Public Key
NEXT_PUBLIC_USER_ID=your_public_key_here
